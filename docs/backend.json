{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "dietaryPreference": { "type": "string" },
        "healthGoal": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "age", "gender", "dietaryPreference", "healthGoal", "createdAt"]
    },
    "UserActivity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserActivity",
      "type": "object",
      "description": "Represents a log of a user's interaction, such as a food scan or recipe generation.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["scan", "recipe"] },
        "title": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["id", "type", "title", "timestamp"]
    },
    "UserFavorite": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserFavorite",
      "type": "object",
      "description": "Represents a food item or recipe favorited by the user.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["food", "recipe"] },
        "title": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["id", "type", "title", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/activities/{activityId}",
        "definition": {
          "entityName": "UserActivity",
          "schema": { "$ref": "#/backend/entities/UserActivity" },
          "description": "Subcollection for user activity logs."
        }
      },
      {
        "path": "/users/{userId}/favorites/{favoriteId}",
        "definition": {
          "entityName": "UserFavorite",
          "schema": { "$ref": "#/backend/entities/UserFavorite" },
          "description": "Subcollection for user favorites."
        }
      }
    ]
  }
}